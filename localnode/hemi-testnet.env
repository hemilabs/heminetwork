# Can be "mainnet" or "sepolia"
NETWORK=sepolia
 
# Etherscan API key used to verify contract bytecode
ETHERSCAN_API_KEY=fakekey
 
# RPC URL for the L1 network that matches $NETWORK
ETH_RPC_URL=http://172.17.0.1:9988
 
# Private key used to deploy the new contracts for this upgrade
# not real; grabbed from hardhat.fork()
PRIVATE_KEY=0xdfe61681b31b12b04f239bc0692965c61ffc79244ed9736ffa1a72d00a23a530
 
# Base fee scalar for the SystemConfig
BASE_FEE_SCALAR=1
 
# Blob base fee scalar for the SystemConfig
BLOB_BASE_FEE_SCALAR=1


OP_CONTRACTS_RELEASE=v1.8.0-rc.4

SYSTEM_OWNER_SAFE=0x382D0AA958998408DD7695c8965C46BdaBBC3003
PREIMAGE_ORACLE_ADDR=0x0000000000000000000000000000000000000000
ANCHOR_STATE_REGISTRY_PROXY_ADDR=0x0000000000000000000000000000000000000000
PROXY_ADMIN_ADDR=0xc43ED1E8D70d0e5801514833fAD3D93Ba16Da4Aa
SUPERCHAIN_CONFIG_PROXY_ADDR=0x0000000000000000000000000000000000000000
SYSTEM_CONFIG_PROXY_ADDR=0xfa73580F4D72294Ae9EE3DAaC36D8bF111B37Ce9
DISPUTE_GAME_FACTORY_PROXY_ADDR=0x0000000000000000000000000000000000000000
